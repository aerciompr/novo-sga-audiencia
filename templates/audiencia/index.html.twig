{% extends 'base.html.twig' %}

{% trans_default_domain 'AudienciaBundle' %}

{% block body %}
    <div id="audiencia" v-cloak>
        <div class="row mb-3">
            <div class="col-md-4">
                <a href="#dialog-local" data-toggle="modal" class="btn btn-outline-secondary btn-block">
                    <strong v-text="usuario.local ? usuario.local.nome : '{{ 'label.place'|trans }}'"></strong>
                    <span class="ml-2" v-text="usuario.numeroLocal"></span>
                </a>
            </div>
            <div class="col-md-8 text-right">
                <button type="button" class="btn btn-secondary" :disabled="!atendimento || busy" @click="rechamarAtual">
                    {{ 'button.call_again'|trans }}
                </button>
                <button type="button" class="btn btn-primary" :disabled="!atendimento || atendimento.status !== 'chamado' || busy" @click="iniciar">
                    {{ 'button.start'|trans }}
                </button>
                <button type="button" class="btn btn-warning" :disabled="!atendimento || busy" @click="naoCompareceu">
                    {{ 'button.no_show'|trans }}
                </button>
                <button type="button" class="btn btn-success" :disabled="!atendimento || busy" @click="encerrar">
                    {{ 'button.finish'|trans }}
                </button>
            </div>
        </div>

        <div class="card mb-3" v-if="atendimento">
            <div class="card-header">{{ 'label.current_call'|trans }}</div>
            <div class="card-body">
                <strong>{% verbatim %}{{ atendimento.senha.format }}{% endverbatim %}</strong>
                <span class="ml-2">{% verbatim %}{{ atendimento.servico.nome }}{% endverbatim %}</span>
                <span class="badge badge-info ml-2">{% verbatim %}{{ atendimento.status }}{% endverbatim %}</span>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">{{ 'label.new_audience'|trans }}</div>
            <div class="card-body">
                <form class="form-inline" @submit.prevent="criarAudiencia">
                    <input type="text" class="form-control mr-2" v-model="novo.tituloAudiencia" :placeholder="labels.audienceTitle" required>
                    <input type="text" class="form-control mr-2" v-model="novo.salaAudiencia" :placeholder="labels.audienceRoom" required>
                    <button type="submit" class="btn btn-primary" :disabled="busy">{{ 'button.create_audience'|trans }}</button>
                </form>
            </div>
        </div>

        <div class="mb-3">
            <div class="btn-group" role="group">
                <button type="button" class="btn" :class="filtroStatus === 'ativas' ? 'btn-primary' : 'btn-outline-primary'" @click="alterarFiltro('ativas')">
                    {{ 'filter.active'|trans }}
                </button>
                <button type="button" class="btn" :class="filtroStatus === 'finalizadas' ? 'btn-primary' : 'btn-outline-primary'" @click="alterarFiltro('finalizadas')">
                    {{ 'filter.finished'|trans }}
                </button>
                <button type="button" class="btn" :class="filtroStatus === 'todas' ? 'btn-primary' : 'btn-outline-primary'" @click="alterarFiltro('todas')">
                    {{ 'filter.all'|trans }}
                </button>
            </div>
        </div>

        <div class="card mb-3" v-for="audiencia in audiencias" :key="audiencia.id">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>{% verbatim %}{{ audiencia.titulo }}{% endverbatim %}</strong>
                <div>
                    <span class="badge badge-light">{% verbatim %}{{ audiencia.sala }}{% endverbatim %}</span>
                    <button type="button" class="btn btn-sm btn-success ml-2" :disabled="busy" @click="finalizarAudiencia(audiencia)" v-if="audiencia.status === 'ativa'">
                        {{ 'button.finish_audience'|trans }}
                    </button>
                </div>
            </div>
            <div class="card-body">
                <form class="form-row align-items-end mb-3" @submit.prevent="adicionarParte(audiencia)">
                    <div class="col-md-9">
                        <label class="small">{{ 'label.part_name'|trans }}</label>
                        <input type="text" class="form-control" v-model="audiencia._novaParteNome" :placeholder="labels.partName" required>
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-outline-primary btn-block" :disabled="busy">{{ 'button.add_part'|trans }}</button>
                    </div>
                </form>

                <div v-if="!audiencia.partes || audiencia.partes.length === 0" class="text-muted">{{ 'label.no_parts'|trans }}</div>

                <div class="card mb-2" v-for="parte in audiencia.partes" :key="parte.id">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <strong>{% verbatim %}{{ parte.nome }}{% endverbatim %}</strong>
                                <span class="badge badge-info ml-2">{% verbatim %}{{ labels.status[parte.situacao] || parte.situacao }}{% endverbatim %}</span>
                            </div>
                            <div>
                                <button type="button" class="btn btn-sm btn-primary" :disabled="busy" @click="chamarPessoa(parte)" v-if="parte.atendimento_status !== 'iniciado'">
                                    {{ 'button.call_part'|trans }}
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-danger" :disabled="busy" @click="removerParte(parte)" v-if="parte.atendimento_status !== 'iniciado'">
                                    {{ 'button.delete_part'|trans }}
                                </button>
                            </div>
                        </div>

                        <form class="form-row align-items-end mb-2" @submit.prevent="adicionarTestemunha(audiencia, parte)">
                            <div class="col-md-9">
                                <label class="small">{{ 'label.witness_name'|trans }}</label>
                                <input type="text" class="form-control" v-model="parte._novaTestemunhaNome" :placeholder="labels.witnessName" required>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-outline-secondary btn-block" :disabled="busy">{{ 'button.add_witness'|trans }}</button>
                            </div>
                        </form>

                        <ul class="list-group" v-if="parte.testemunhas && parte.testemunhas.length">
                            <li class="list-group-item d-flex justify-content-between align-items-center" v-for="testemunha in parte.testemunhas" :key="testemunha.id">
                                <div>
                                    {% verbatim %}{{ testemunha.nome }}{% endverbatim %}
                                    <span class="badge badge-info ml-2">{% verbatim %}{{ labels.status[testemunha.situacao] || testemunha.situacao }}{% endverbatim %}</span>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-primary" :disabled="busy" @click="chamarPessoa(testemunha)" v-if="testemunha.situacao !== 'compareceu' && testemunha.situacao !== 'finalizado'">
                                        {{ 'button.call_witness'|trans }}
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-danger" :disabled="busy" @click="removerTestemunha(testemunha)">
                                        {{ 'button.delete_witness'|trans }}
                                    </button>
                                </div>
                            </li>
                        </ul>
                        <small class="text-muted" v-else>{{ 'label.no_witnesses'|trans }}</small>
                    </div>
                </div>
            </div>
        </div>

        <div id="dialog-local" class="modal fade" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form @submit.prevent="setLocal">
                        <div class="modal-header">
                            <h5 class="modal-title">{{ 'modal.place'|trans }}</h5>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <div class="form-group">
                                <label>{{ 'label.place.number'|trans }}</label>
                                <input type="number" class="form-control" v-model.number="novoLocal.numeroLocal" required>
                            </div>
                            <div class="form-group">
                                <label>{{ 'label.attendance_type'|trans }}</label>
                                <select class="form-control" v-model="novoLocal.tipoAtendimento" required>
                                    {% for value, label in tiposAtendimento %}
                                        <option value="{{ value }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="form-group">
                                <label>{{ 'label.place'|trans }}</label>
                                <select class="form-control" v-model="novoLocal.local" required>
                                    {% for l in locais %}
                                        <option :value="{{ l.id }}">{{ l.nome }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary">{{ 'button.save'|trans }}</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        const local = {{ local|json_encode|raw }};
        const numeroLocal = {{ numeroLocal ? numeroLocal : 'null' }};
        const usuario = {{ usuario|json_encode()|raw }};
        const unidade = {{ unidade|json_encode()|raw }};
        const atendimento = {{ atendimento|json_encode()|raw }};
        const tipoAtendimento = "{{ tipoAtendimento ? tipoAtendimento : 'null' }}";
        const tiposAtendimento = {{ tiposAtendimento|json_encode()|raw }};

        new Vue({
            el: '#audiencia',
            data: {
                busy: false,
                usuario: {
                    id: usuario.id,
                    local: local,
                    numeroLocal: numeroLocal,
                    tipoAtendimento: tipoAtendimento,
                },
                unidade: unidade || {},
                atendimento: atendimento || null,
                tiposAtendimento: tiposAtendimento,
                audiencias: [],
                filtroStatus: 'ativas',
                novo: {
                    tituloAudiencia: '',
                    salaAudiencia: '',
                },
                novoLocal: {
                    local: local ? local.id : null,
                    numeroLocal: numeroLocal,
                    tipoAtendimento: tipoAtendimento,
                },
                labels: {
                    audienceTitle: '{{ 'label.audience_title_placeholder'|trans }}',
                    audienceRoom: '{{ 'label.audience_room_placeholder'|trans }}',
                    partName: '{{ 'label.part_name_placeholder'|trans }}',
                    witnessName: '{{ 'label.witness_name_placeholder'|trans }}',
                    status: {
                        aguardando: '{{ 'status.waiting'|trans }}',
                        chamado: '{{ 'status.called'|trans }}',
                        compareceu: '{{ 'status.checked_in'|trans }}',
                        iniciado: '{{ 'status.in_progress'|trans }}',
                        finalizado: '{{ 'status.done'|trans }}',
                        nao_compareceu: '{{ 'status.no_show'|trans }}',
                    }
                },
            },
            methods: {
                carregarAudiencias() {
                    App.ajax({
                        url: App.url('/audiencia/audiencias'),
                        data: { status: this.filtroStatus },
                        success: (response) => {
                            this.audiencias = (response.data || []).map((audiencia) => {
                                audiencia._novaParteNome = '';
                                (audiencia.partes || []).forEach((parte) => {
                                    parte._novaTestemunhaNome = '';
                                });
                                return audiencia;
                            });
                        },
                    });
                },
                alterarFiltro(status) {
                    this.filtroStatus = status;
                    this.carregarAudiencias();
                },
                carregarAtendimentoAtual() {
                    App.ajax({
                        url: App.url('/audiencia/atendimento'),
                        success: (response) => {
                            this.atendimento = response.data || null;
                        },
                    });
                },
                setLocal() {
                    App.ajax({
                        url: App.url('/audiencia/set_local'),
                        type: 'post',
                        data: this.novoLocal,
                        success: (response) => {
                            this.usuario.local = response.data.local;
                            this.usuario.numeroLocal = response.data.numero;
                            this.usuario.tipoAtendimento = response.data.tipo;
                            this.novoLocal.local = response.data.local.id;
                            $('#dialog-local').modal('hide');
                        },
                    });
                },
                criarAudiencia() {
                    if (!this.novo.tituloAudiencia || !this.novo.salaAudiencia) {
                        return;
                    }
                    this.busy = true;
                    App.ajax({
                        url: App.url('/audiencia/audiencias'),
                        type: 'post',
                        data: { titulo: this.novo.tituloAudiencia, sala: this.novo.salaAudiencia },
                        success: () => {
                            this.novo.tituloAudiencia = '';
                            this.novo.salaAudiencia = '';
                            this.carregarAudiencias();
                        },
                        complete: () => this.busy = false,
                    });
                },
                adicionarParte(audiencia) {
                    if (!audiencia._novaParteNome) {
                        return;
                    }
                    this.busy = true;
                    App.ajax({
                        url: App.url('/audiencia/audiencias/' + audiencia.id + '/partes'),
                        type: 'post',
                        data: {
                            nome: audiencia._novaParteNome,
                        },
                        success: () => {
                            audiencia._novaParteNome = '';
                            this.carregarAudiencias();
                        },
                        complete: () => this.busy = false,
                    });
                },
                finalizarAudiencia(audiencia) {
                    if (!confirm('{{ 'confirm.finish_audience'|trans }}')) {
                        return;
                    }
                    this.busy = true;
                    App.ajax({
                        url: App.url('/audiencia/audiencias/' + audiencia.id + '/finalizar'),
                        type: 'post',
                        success: () => {
                            this.atendimento = null;
                            this.carregarAudiencias();
                            this.carregarAtendimentoAtual();
                        },
                        complete: () => this.busy = false,
                    });
                },
                adicionarTestemunha(audiencia, parte) {
                    if (!parte._novaTestemunhaNome) {
                        return;
                    }
                    this.busy = true;
                    App.ajax({
                        url: App.url('/audiencia/audiencias/' + audiencia.id + '/testemunhas'),
                        type: 'post',
                        data: {
                            parteId: parte.id,
                            nome: parte._novaTestemunhaNome,
                        },
                        success: () => {
                            parte._novaTestemunhaNome = '';
                            this.carregarAudiencias();
                        },
                        complete: () => this.busy = false,
                    });
                },
                removerParte(parte) {
                    if (!confirm('{{ 'confirm.delete_part'|trans }}')) {
                        return;
                    }
                    this.busy = true;
                    App.ajax({
                        url: App.url('/audiencia/partes/' + parte.id),
                        type: 'delete',
                        success: () => this.carregarAudiencias(),
                        complete: () => this.busy = false,
                    });
                },
                removerTestemunha(testemunha) {
                    if (!confirm('{{ 'confirm.delete_witness'|trans }}')) {
                        return;
                    }
                    this.busy = true;
                    App.ajax({
                        url: App.url('/audiencia/testemunhas/' + testemunha.id),
                        type: 'delete',
                        success: () => this.carregarAudiencias(),
                        complete: () => this.busy = false,
                    });
                },
                chamarPessoa(pessoa) {
                    this.busy = true;
                    App.ajax({
                        url: App.url('/audiencia/pessoas/' + pessoa.id + '/chamar'),
                        type: 'post',
                        success: (response) => {
                            this.atendimento = response.data || null;
                            this.carregarAtendimentoAtual();
                        },
                        complete: () => {
                            setTimeout(() => this.busy = false, 1000);
                        },
                    });
                },
                rechamarAtual() {
                    if (!this.atendimento) {
                        return;
                    }
                    const pessoaId = this.buscarPessoaPorAtendimento(this.atendimento.id);
                    if (!pessoaId) {
                        return;
                    }
                    this.busy = true;
                    App.ajax({
                        url: App.url('/audiencia/pessoas/' + pessoaId + '/chamar'),
                        type: 'post',
                        complete: () => {
                            setTimeout(() => this.busy = false, 1000);
                        },
                    });
                },
                buscarPessoaPorAtendimento(atendimentoId) {
                    let pessoaId = null;
                    this.audiencias.forEach((audiencia) => {
                        (audiencia.partes || []).forEach((parte) => {
                            if (parte.atendimento_id === atendimentoId) {
                                pessoaId = parte.id;
                            }
                            (parte.testemunhas || []).forEach((testemunha) => {
                                if (testemunha.atendimento_id === atendimentoId) {
                                    pessoaId = testemunha.id;
                                }
                            });
                        });
                    });
                    return pessoaId;
                },
                iniciar() {
                    App.ajax({
                        url: App.url('/audiencia/iniciar'),
                        type: 'post',
                        success: (response) => {
                            this.atendimento = response.data;
                            this.carregarAudiencias();
                        },
                    });
                },
                naoCompareceu() {
                    App.ajax({
                        url: App.url('/audiencia/nao_compareceu'),
                        type: 'post',
                        success: () => {
                            this.atendimento = null;
                            this.carregarAudiencias();
                        },
                    });
                },
                encerrar() {
                    App.ajax({
                        url: App.url('/audiencia/encerrar'),
                        type: 'post',
                        success: () => {
                            this.atendimento = null;
                            this.carregarAudiencias();
                        },
                    });
                },
            },
            mounted() {
                if (!this.usuario.local) {
                    $('#dialog-local').modal('show');
                }

                this.carregarAudiencias();
                this.carregarAtendimentoAtual();

                App.SSE.connect([
                    '/unidades/' + this.unidade.id + '/fila',
                    '/usuarios/' + this.usuario.id + '/fila',
                ]);

                App.SSE.onmessage = () => {
                    this.carregarAtendimentoAtual();
                };
            },
        });
    </script>
{% endblock %}
